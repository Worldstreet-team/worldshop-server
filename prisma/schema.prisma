// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  completed   Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// USER PROFILE
// Extends the external auth user with shop-specific data.
// `userId` is the user ID from WorldStreet Identity service.
// ============================================

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Role {
  CUSTOMER
  ADMIN
}

enum VendorStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model UserProfile {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @unique // maps to Clerk user id
  email            String        @unique
  firstName        String
  lastName         String
  phone            String?
  avatar           String?
  dateOfBirth      DateTime?
  gender           Gender?
  role             Role          @default(CUSTOMER)

  // Vendor fields
  isVendor         Boolean       @default(false)
  vendorStatus     VendorStatus?
  storeName        String?       @unique
  storeSlug        String?       @unique
  storeDescription String?
  vendorSince      DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// ============================================
// ADDRESSES
// Saved delivery addresses per user (max 5).
// Country defaults to Nigeria with Nigerian states.
// ============================================

model Address {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   // maps to external auth user id
  label       String?  // "Home", "Office", etc.
  firstName   String
  lastName    String
  phone       String
  street      String
  apartment   String?
  city        String
  state       String
  country     String   @default("Nigeria")
  postalCode  String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ============================================
// CATEGORIES
// Hierarchical product categories with self-referential parent/child.
// ============================================

model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String     @unique
  description String?
  image       String?
  icon        String?

  parentId    String?    @db.ObjectId
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Category[] @relation("CategoryTree")

  products    Product[]

  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
}

// ============================================
// PRODUCTS
// Core product catalog with images, variants, and category relation.
// All prices stored in NGN (₦).
// ============================================

model Product {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String           @unique
  description   String
  shortDesc     String?
  stockKeepingUnit String?       @unique
  basePrice     Float            // Price in NGN (₦)
  salePrice     Float?
  type          String           @default("PHYSICAL") // PHYSICAL or DIGITAL

  categoryId    String?          @db.ObjectId
  category      Category?        @relation(fields: [categoryId], references: [id])

  // Vendor ownership (null = platform-owned, admin-managed)
  vendorId      String?
  approvalStatus String          @default("APPROVED") // PENDING, APPROVED, REJECTED

  brand         String?
  tags          String[]
  images        Json       @default("[]") // Array of { key, alt, isPrimary, sortOrder }

  // Digital product assets (only for type=DIGITAL)
  digitalAssets DigitalAsset[]

  variants      ProductVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  avgRating     Float            @default(0)
  reviewCount   Int              @default(0)
  stock         Int              @default(0)
  lowStockThreshold Int          @default(10)

  isActive      Boolean          @default(true)
  isFeatured    Boolean          @default(false)
  isNewArrival  Boolean          @default(true)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
  @@index([isActive])
  @@index([vendorId])
}

model ProductVariant {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  productId      String   @db.ObjectId
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockKeepingUnit String? @unique
  name           String
  attributes     Json     // { size: "XL", color: "Red" }
  price          Float?   // Override price in NGN
  compareAtPrice Float?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)

  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([productId])
}

// ============================================
// CART
// Session-based (guest) or user-based cart with items.
// Guest carts use sessionId; authenticated users use userId.
// ============================================

model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?    @unique // Authenticated user (one cart per user)
  sessionId String?    @unique // Guest session ID
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId    String   @db.ObjectId
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?  @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// ============================================
// ORDERS
// Complete order with items, shipping, and status history.
// All amounts in NGN (₦).
// ============================================

enum OrderStatus {
  CREATED      // Order created, awaiting payment
  PAID         // Payment confirmed
  PROCESSING   // Being prepared for shipment
  SHIPPED      // Shipped to customer
  DELIVERED    // Delivered to customer
  CANCELLED    // Cancelled by user or admin
  REFUNDED     // Full refund issued
}

model Order {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String               @unique
  userId            String               // maps to external auth user id
  vendorId          String?              // vendor user id (null = platform-owned)
  checkoutSessionId String?              // groups orders from a single checkout
  status            OrderStatus          @default(CREATED)

  items           OrderItem[]
  statusHistory   OrderStatusHistory[]

  // Shipping address (optional for digital orders)
  shippingAddress Json?                // { firstName, lastName, address, city, state, country, phone, postalCode }
  billingAddress  Json?                // Optional separate billing address

  // Totals in NGN
  subtotal        Float
  shipping        Float                @default(0)
  discount        Float                @default(0)
  total           Float

  couponCode      String?
  notes           String?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  refundedAt      DateTime?

  @@index([userId])
  @@index([status])
  @@index([vendorId])
  @@index([checkoutSessionId])
}

model OrderItem {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  orderId      String          @db.ObjectId
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String          @db.ObjectId
  product      Product         @relation(fields: [productId], references: [id])
  variantId    String?         @db.ObjectId
  variant      ProductVariant? @relation(fields: [variantId], references: [id])

  // Snapshot at time of order (prices can change)
  productName  String
  productImage String?
  sku          String?
  variantName  String?
  quantity     Int
  unitPrice    Float           // Price per unit in NGN at time of order
  totalPrice   Float           // quantity * unitPrice

  createdAt    DateTime        @default(now())

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String      @db.ObjectId
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

// ============================================
// PAYMENTS
// Payment records linked to checkout sessions.
// Amounts stored in NGN (₦).
// ============================================

enum PaymentStatus {
  PENDING    // Awaiting payment
  COMPLETED  // Payment successful
  FAILED     // Payment declined / failed
  REFUNDED   // Full refund issued
}

model Payment {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  checkoutSessionId String?       @unique            // links to the checkout session
  userId            String                           // maps to external auth user id
  amount            Float                            // Amount in NGN
  currency          String        @default("NGN")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("mock")
  transactionRef    String?       @unique            // Unique transaction reference
  providerData      Json?                            // Provider-specific data
  metadata          Json?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paidAt            DateTime?

  @@index([userId])
}

// ============================================
// REVIEWS
// Product reviews by authenticated users.
// One review per user per product. Auto-verified if user purchased the product.
// ============================================

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String   // maps to external auth user id
  userName   String   // display name snapshot
  rating     Int      // 1-5
  title      String?
  comment    String
  isVerified Boolean  @default(false) // true if user has a DELIVERED order with this product

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ============================================
// WISHLIST
// One wishlist per user with multiple items.
// ============================================

model Wishlist {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  userId    String         @unique // maps to external auth user id
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  wishlistId String   @db.ObjectId
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@unique([wishlistId, productId])
  @@index([wishlistId])
}

// ============================================
// DIGITAL ASSETS
// Files attached to DIGITAL products (PDFs, docs, etc.).
// Stored in R2 under "digital-products/" folder.
// ============================================

model DigitalAsset {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @db.ObjectId
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  fileName      String            // Original file name shown to users
  r2Key         String            // R2 object key (e.g. "digital-products/abc123.pdf")
  mimeType      String            // e.g. "application/pdf"
  fileSize      Int               // Size in bytes
  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

// ============================================
// DOWNLOAD RECORDS
// Tracks download attempts per order item.
// Max 5 downloads allowed per order item.
// ============================================

model DownloadRecord {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId   String   @db.ObjectId
  userId        String   // External auth user id
  assetId       String   @db.ObjectId

  downloadCount Int      @default(0) // Current download count
  maxDownloads  Int      @default(5) // Max allowed downloads
  expiresAt     DateTime            // Signed URL expiry (7 days from purchase)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([orderItemId, assetId])
  @@index([userId])
  @@index([orderItemId])
}

// ============================================
// PLATFORM CONFIG
// Key-value settings (e.g. commissionRate).
// ============================================

model PlatformConfig {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value Json
}

// ============================================
// LEDGER ENTRY
// Immutable financial audit trail per vendor.
// Types: SALE (vendor net), COMMISSION (platform fee), WITHDRAWAL.
// ============================================

enum LedgerEntryType {
  SALE
  COMMISSION
  WITHDRAWAL
}

model LedgerEntry {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String          @db.ObjectId
  vendorId      String          // External auth user id
  type          LedgerEntryType
  amount        Float           // Positive = credit, negative = debit
  currency      String          @default("NGN")
  balanceBefore Float
  balanceAfter  Float
  createdAt     DateTime        @default(now())

  @@index([vendorId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// VENDOR BALANCE
// Running balance per vendor.
// ============================================

model VendorBalance {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  vendorId        String   @unique // External auth user id
  availableBalance Float   @default(0)
  totalEarned     Float    @default(0)
  totalCommission Float    @default(0)
  updatedAt       DateTime @updatedAt
}
